/*
You are given 2 numbers n and m, the task is to find n√m (nth root of m). If the root is not integer then return -1.

Examples :
Input: n = 3, m = 8
Output: 2
Explanation: 23 = 8

Input: n = 3, m = 9
Output: -1
Explanation: 3rd root of 9 is not integer.
*/

//Code:
class Solution {
  public:
    int nthRoot(int n, int m) {
        if(m==0) return 0;
        if(n==0)
        {
            if(m==1) return 1;
            return -1;
        }
        
        int low=1,high=m;
        while(low<=high)
        {
            int mid=low+(high-low)/2;
            
            long long mul=1;
            
            for(int i=1;i<=n;i++)//calculate mid^n
            {
                mul=mul*mid;
                
                
                if(mul>m) break;
            }
            
            if(mul==m) return mid;
            else if(mul<m) low=mid+1;
            else high=mid-1;
        }
        return -1;
    }
};

//Time: O(log m)
//Space: O(1)
