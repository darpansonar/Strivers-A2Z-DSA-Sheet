/*
Given two positive integer n and  k, check if the kth index bit of n is set or not.
Note: A bit is called set if it is 1. 

Example: 
Input: n = 4, k = 2
Output: true
Explanation: Binary representation of 4 is 100, in which 2nd index bit from LSB is set. So, return true.

Input: n = 500, k = 3
Output: false
Explanation: Binary representation of 500 is 111110100, in which 3rd index bit from LSB is not set. So, return false.
*/

//Approach 1:
class Solution {
  public:
    bool checkKthBit(int n, int k) {
        // let n=13 and k=2
        // 13   = 1 1 0 1
        // 1<<2 =   1 0 0 //1 is left shifted by k(i.e 2)
        // (13 & (1<<2) = 0 1 0 0) i.e, kth bit is set
        
        if(n&(1<<(k))!=0)
             return true;
         else 
             return false;
    }
};

//Time: O(1)
//Space: O(1)

//Approach 2:
class Solution {
  public:
    bool checkKthBit(int n, int k) {
        // right shift n by k bits
        // n=13 and k=2
        // 13    = 1 1 0 1
        // 13>>2 =     1 1
        // (13>>2)&1 = 0 1 i.e kth bit is set
        
        if((n>>k)&1 !=0)
            return true;
        else
            return false;
    }
};

//Time: O(1)
//Space: O(1)
