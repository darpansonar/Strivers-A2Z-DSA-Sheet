/*
Given an array of integers nums and an integer k, return the total number of subarrays whose sum equals to k.
A subarray is a contiguous non-empty sequence of elements within an array.

Example 1:
Input: nums = [1,1,1], k = 2
Output: 2
Example 2:

Input: nums = [1,2,3], k = 3
Output: 2
*/

//Code:
//Approach 1:
class Solution {
public:
    int subarraySum(vector<int>& nums, int k) {
        //Brute force
        int n=nums.size();
        int cnt=0;

        for(int i=0;i<n;i++)
        {
            int sum=0;
            for(int j=i;j<n;j++)
            {
                sum=sum+nums[j];
                if(sum==k)
                {
                    cnt++;
                }
            }
        }
        return cnt;
    }
};

//Time : O(n^2)
//Space : O(1)

//Approach 2:
class Solution {
public:
    int subarraySum(vector<int>& nums, int k) {
        //Using sliding window(when only positive numbers)
        int l=0,r=0,n=nums.size(),maxLen=0,sum=nums[0];
        while(r<n)
        {
            //if sum>k,shrink it
            while(l<=r && sum>k)
            {
                sum = sum - nums[l];
                l++;
            }

            if(sum==k && l<=r) maxLen=max(maxLen,r-l+1);

            r++;

            if(r<n) sum = sum + nums[r];
        }
        return maxLen;
    }
};

//Time : O(n)
//Space : O(1)
