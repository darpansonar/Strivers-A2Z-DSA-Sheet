/*
Given an integer n, return true if it is a power of two. Otherwise, return false.
An integer n is a power of two, if there exists an integer x such that n == 2^x.

Example:
Input: n = 1
Output: true
Explanation: 20 = 1

Example 2:
Input: n = 16
Output: true
Explanation: 24 = 16
*/

//Code:
//Approach 1:
class Solution {
public:
    bool isPowerOfTwo(int n) {
        long long result=1;
        long long x=0;
        if(n==1) return true;
        while(x>=0)
        {
            result=2*result;
            if(result==n) return true;
            if(result>n) break;
            x++;
        }
        return false;
    }
};

//Time: O(log n)
//Space: O(1)

//Approach 2:
class Solution {
public:
    bool isPowerOfTwo(int n) {
        //WKT, n>>k = n/(2^k)
        if (n <= 0) return false;
        while (n > 1) 
        {
            if (n % 2 != 0) return false; // If there's a remainder, it's not a power of 2
            n = n >> 1; // Divide by 2
        }
        return true;
    }
};

//Time: O(log n)
//Space: O(1)

//Approach 3:
class Solution {
public:
    bool isPowerOfTwo(int n) {
        // 16 = 1 0 0 0 0
        // 15 = 0 1 1 1 1
        // 16&15 = 0 0 0 0 0
        // if(16&15 = 0) then the number is power of two

        if(n>0 && (n&(n-1))==0) return true;
        else return false;
    }
};

//Time: O(1)
//Space: O(1)
