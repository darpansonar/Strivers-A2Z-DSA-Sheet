/*
Given the root of a binary tree. Your task is to return the left view of the binary tree. The left view of a binary tree is the set of nodes visible when the tree is viewed from the left side.
Note: If the tree is empty, return an empty list.

Example:
Input: root = [1, 2, 3, 4, 5, N, N]
Output:[1, 2, 4]
Explanation: From the left side of the tree, only the nodes 1, 2, and 4 are visible.
*/

//Code:
//Approach 1:
class Solution {
  public:
    vector<int> leftView(Node *root) {
        // code here
        //Here, we have to print 1st node of each level
        vector<int> ans;
        if(root==NULL) return ans;
        
        queue<Node*> q;
        q.push(root);
        
        while(!q.empty())
        {
            int levelSize=q.size();
            vector<int> level;
            
            for(int i=0;i<levelSize;i++)
            {
                Node *currNode=q.front();
                q.pop();
                
                level.push_back(currNode->data);
                
                if(currNode->left!=NULL) q.push(currNode->left);
                if(currNode->right!=NULL) q.push(currNode->right);
            }
            ans.push_back(level[0]);  
        }
        return ans;
    }
};

//Time: O(n)
//Space: O(n)
//Auxillary space: O(n)

//Approach 2:
class Solution {
  public:
    void solve(Node *root,int level,vector<int> &ans)
    {
        //base case
        if(root==NULL) return;
        
        // If we are visiting this level for the first time, then this node is the leftmost node of that level.
        //We have entered into a new level
        if(level==ans.size()) ans.push_back(root->data);
        
        // Traverse left subtree first so that leftmost node is visited before the right subtree.
        solve(root->left,level+1,ans);
        // Traverse right subtree
        solve(root->right,level+1,ans);
    }
    vector<int> leftView(Node *root) {
        vector<int> ans;
        solve(root,0,ans);
        return ans;
    }
};

//Time: O(n)
//Space: O(h)
//Auxillary space: O(h)
