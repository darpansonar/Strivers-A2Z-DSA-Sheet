/*
Given the root of a binary Tree. Return the right view of the binary tree. The right view of a Binary Tree is the set of nodes visible when the tree is viewed from the right side.

Example:
Input: root = [1, 2, 3, N, N, 4, 5]
Output: [1, 3, 5]
*/

//Code:
//Approach 1:
class Solution {
  public:
    vector<int> rightView(Node *root) {
        //  code here
        //Here, we have to print last node of each level
        vector<int> ans;
        if(root==NULL) return ans;
        
        queue<Node*> q;
        q.push(root);
        
        while(!q.empty())
        {
            int levelSize=q.size();
            vector<int> level;
            
            for(int i=0;i<levelSize;i++)
            {
                Node *currNode=q.front();
                q.pop();
                
                level.push_back(currNode->data);
                
                if(currNode->left!=NULL) q.push(currNode->left);
                if(currNode->right!=NULL) q.push(currNode->right);
            }
            ans.push_back(level[levelSize-1]);  
        }
        return ans;
    }
};

//Time: O(n)
//Space: O(n)
//Auxillary space: O(n)

//Approach 2:
class Solution {
  public:
    void solve(Node *root,int level,vector<int> &ans)
    {
        if(root==NULL) return;
        
        // If we are visiting this level for the first time, then this node is the leftmost node of that level.
        //We have entered into a new level
        if(level==ans.size()) ans.push_back(root->data);
        
        // Traverse right subtree first so that rightmost node is visited before the left subtree.
        solve(root->right,level+1,ans);
        
        //Traverse left subtree
        solve(root->left,level+1,ans);
    }
    vector<int> rightView(Node *root) {
        vector<int> ans;
        solve(root,0,ans);
        return ans;
    }
};

//Time: O(n)
//Space: O(h)
//Auxillary space: O(h)
