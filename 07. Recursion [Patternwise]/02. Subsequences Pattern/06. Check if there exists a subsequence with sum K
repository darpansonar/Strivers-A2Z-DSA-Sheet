/*
Given an array arr and target sum k, check whether there exists a subsequence such that the sum of all elements in the subsequence equals to k.

Example:
Input: arr = [10, 1, 2, 7, 6, 1, 5], k = 8.
Output: true
Explanation: Subsequences like [2, 6], [1, 7] sum upto 8
*/

//Approach:
class Solution {
  public:
    bool solve(vector<int>& arr, int sum,int i)
    {
        // Base case: if all elements are processed, check if sum is 0
        if(i==arr.size())
            return sum==0;
        
        // Recursive call: include the current element in the subsequence or exclude the current element from the subsequence
        return solve(arr,sum-arr[i],i+1) || solve(arr,sum,i+1);
    }
    bool checkSubsequenceSum(vector<int>& arr, int k) {
        return solve(arr,k,0);
    }
};

//Time: O(2ⁿ) (all subsequences)
//Space: O(n) (recursion stack)
