/*
The Fibonacci numbers, commonly denoted F(n) form a sequence, called the Fibonacci sequence, such that each number is the sum of the two preceding ones, starting from 0 and 1. That is,
F(0) = 0, F(1) = 1
F(n) = F(n - 1) + F(n - 2), for n > 1.
Given n, calculate F(n).

Example 1:
Input: n = 2
Output: 1
Explanation: F(2) = F(1) + F(0) = 1 + 0 = 1.
*/

//Code:
//Appproach 1:
class Solution {
public:
    int fib(int n) {
        if(n==0) return 0;
        else if(n==1) return 1;

        vector<int> fib(n+1);
        fib[0]=0;
        fib[1]=1;

        for(int i=2;i<=n;i++)
        {
            fib[i]=fib[i-1]+fib[i-2];
        }
        return fib[n];
    }
};

//Time = O(n)
//Space = O(n)

//Approach 2:
class Solution {
public:
    int fib(int n) {
        if(n==0) return 0;
        else if(n==1) return 1;

        return fib(n-1)+fib(n-2);
    }
};

//Time = O(2^n)
//Space = O(n)

//Approach 3:
int a = 0, b = 1;
for(int i = 2; i <= n; i++) {
    int c = a + b;
    a = b;
    b = c;
}
return b;

//Time = O(n)
//Space = O(1)
