/*
Given an integer array nums of unique elements, return all possible subsets (the power set).
The solution set must not contain duplicate subsets. Return the solution in any order.

Example:
Input: nums = [1,2,3]
Output: [[],[1],[2],[1,2],[3],[1,3],[2,3],[1,2,3]]
*/

//Approach 1: Using bit manipulation
class Solution {
public:
    vector<vector<int>> subsets(vector<int>& nums) {
        // nums=[a,b,c]
        // [000]=[]
        // [001]=[c]
        // [011]=[b,c] and so on...
        // if(n=size) then number of subsets=2pow(n)i.e 1<<n

        int n=nums.size();
        vector<vector<int>>res;

        for(int i=0;i<(1<<n);i++)
        {
            vector<int> subset;
            for(int j=0;j<n;j++)
            {
                //If the j-th bit of i is set, include nums[j] in the subset.
                if((i&(1<<j))!=0)
                    subset.push_back(nums[j]);
            }
            res.push_back(subset);
        }
        return res;
    }
};

//Time: O(n * 2^n)
//Space: O(n * 2^n)
//Auxillary Space: O(n)

//Approach 2: Using recursion
//refer https://www.youtube.com/watch?v=pNzljlzDCiI&list=PLfqMhTWNBTe2C_dQAP1UoemcgAxBTlItp&index=3 for solution
class Solution {
public:
    void solve(vector<int> &arr,vector<vector<int>> &res,vector<int> &ss,int i)
    {
        if(i==arr.size())
        {
            res.push_back(ss);
            return;
        }

        //Include
        ss.push_back(arr[i]);
        solve(arr,res,ss,i+1);

        //Backtracking
        ss.pop_back();
        //Exclude
        solve(arr,res,ss,i+1);
    }

    vector<vector<int>> subsets(vector<int>& arr) {
        vector<vector<int>> res;
        vector<int> ss; //ss=subset

        solve(arr,res,ss,0);
        return res;
    }
};

//Time: O(n * 2^n)
//Space: O(n * 2^n)
//Auxillary Space: O(n)
