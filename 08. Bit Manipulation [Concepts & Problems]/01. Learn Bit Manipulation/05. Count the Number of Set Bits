/*
Given a positive integer n. Your task is to return the count of set bits.

Example:
Input: n = 6
Output: 2
Explanation: Binary representation is '110', so the count of the set bit is 2.
*/

//Code:
Approach 1:
class Solution {
  public:
    int setBits(int n) {
        int count=0;
        while(n!=0)
        {
            if((n&1)==1) count++; //checking if the last digit  is 1
            n=n>>1; //right shifting
        }
        
        return count;
    }
};

//Time: O(log n)
//Space: O(1)

//Approach 2:
class Solution {
  public:
    int setBits(int n) {
        bitset<32> binaryRep(n);
        return binaryRep.count();
    }
};

//Time: O(1)
//Space: O(1)
