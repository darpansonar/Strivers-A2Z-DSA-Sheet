/*
Given an integer array nums that may contain duplicates, return all possible subsets (the power set).
The solution set must not contain duplicate subsets. Return the solution in any order.

Example:
Input: nums = [1,2,2]
Output: [[],[1],[1,2],[1,2,2],[2],[2,2]]
*/

//Approach:
//refer https://www.youtube.com/watch?v=pNzljlzDCiI&list=PLfqMhTWNBTe2C_dQAP1UoemcgAxBTlItp&index=3 for solution

class Solution {
public:
    void solve(vector<int> &arr,vector<vector<int>> &res,vector<int> &subset,int i,int n)
    {
        if(i==n)
        {
            res.push_back(subset);
            return;
        }

        //include
        subset.push_back(arr[i]); 
        solve(arr,res,subset,i+1,n);
        subset.pop_back(); //backtracking

        //skip duplicate values
        int index=i+1;
        while(index<n && arr[index]==arr[index-1])
            index++;

        solve(arr,res,subset,index,n);
    }

    vector<vector<int>> subsetsWithDup(vector<int>& arr) {
        sort(arr.begin(),arr.end());
        
        int n=arr.size();

        vector<vector<int>> res;
        vector<int> subset;

        solve(arr,res,subset,0,n);
        return res;
    }
};

// Time Complexity: O(n * 2^n)
// Space Complexity: O(n * 2^n)
// Auxiliary Space: O(n)
