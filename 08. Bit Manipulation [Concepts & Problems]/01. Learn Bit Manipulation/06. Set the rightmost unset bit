/*
Given a non-negative number n . The problem is to set the rightmost unset bit in the binary representation of n.

Examples:
Input: n = 6
Output: 7
Explanation: The binary representation of 6 is 110. After setting right most bit it becomes 111 which is 7.

Input: n = 15
Output: 31
Explanation: The binary representation of 15 is 01111. After setting right most bit it becomes 11111 which is 31.
*/

//Code:
//Approach 1:
class Solution {
  public:
    int setBit(int n) {
        // Write Your Code here
        // temp=n=15=01111
        // therefore, k=4
        // 15  = 01111
        // 1<<4= 10000
        // 15|(1<<k)=11111
        
        int k=0;
        int temp=n;
        while(temp>0)
        {
            if((temp&1)==0)
                break;
            temp=temp>>1;
            k++;
        }
        
        n=n|(1<<k);
        return n;
    }
};

//Time: O(log n)
//Space: O(1)

//Approach 2:
class Solution {
public:
    int setBit(int n) {
        //When you add 1 to a number
        //All trailing 1s become 0.
        //The first 0 from the right becomes 1.

        //n      = 01111  (15)
        //n + 1  = 10000  (16)
        //n|(n+1)=11111  (31)

        //n      = 00110  (6)
        //n + 1  = 00111  (7)
        //n|(n+1)=00111  (7)

        return n | (n + 1);
    }
};

//Time: O(1)
//Space: O(1)
