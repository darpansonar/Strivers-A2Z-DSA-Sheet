/*
Given an array of N integers, write a program to implement the Recursive Insertion Sort algorithm.

Example:
Input: N = 6, array[] = {13,46,24,52,20,9}
Output: 9,13,20,24,46,52
Explanation: After sorting we get 9,13,20,24,46,52
*/

//Code:
#include <bits/stdc++.h>
using namespace std;

void insertion_sort(int arr[], int i, int n) {
    // Base Case: if index reaches the size, return
    if (i == n) return;

    int j = i;
    // Shift the element to the left while it's smaller than its predecessor
    while (j > 0 && arr[j - 1] > arr[j]) {
        swap(arr[j] , arr[j-1]);
        j--;
    }

    // Recur for the next index
    insertion_sort(arr, i + 1, n);
}

//Time Complexity: O(N^2)
//Space Complexity: O(N)
