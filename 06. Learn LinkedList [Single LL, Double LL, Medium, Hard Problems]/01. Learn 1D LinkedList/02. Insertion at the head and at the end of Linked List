/*
Problem 1:
You are given the head of a Singly Linked List and a value x, insert that value x at the beginning of the LinkedList and return the head of the modified Linked List.

Example:
Input: x = 1,
    head -> 2 -> 10 -> NULL
Output: 1 -> 2 -> 10
Explanation: We can see that 1 is inserted at the beginning of the linked list.
*/

/*
Structure of the linked list node is as
struct Node {
  int data;
  struct Node *next;
  Node(int x) {
    data = x;
    next = NULL;
  }
}; 
*/

//Code:
class Solution {
  public:
    Node *insertAtBegining(Node *head, int x) {
        Node* temp=new Node(x);
        
        if (head == nullptr) 
        {
            return temp;
        }

        temp->next=head;
        head=temp;
        return head;
    }
};

//Time: O(1)
//Space: O(1)

/*
Problem 2:
You are given the head of a Singly Linked List and a value x, insert that value x at the end of the LinkedList and return the head of the modified Linked List.

Example:
Input: x = 6,
    head -> 1 -> 2 -> 3 -> 4 -> 5 -> NULL
Output: 1 -> 2 -> 3 -> 4 -> 5 -> 6
Explanation: We can see that 6 is inserted at the end of the linkedlist.
*/

//Code:
class Solution {
  public:
    Node *insertAtEnd(Node *head, int x) {
        // Code here
        Node *ptr=new Node(x);
        if (head == NULL) 
        {
            return ptr;
        }
        
        Node *temp=head;
        while(temp->next!=nullptr)
        {
            temp=temp->next;
        }
        
        temp->next=ptr;
        ptr->next=NULL;
        
        return head;
    }
};

//Time: O(n)
//Space: O(1)
