/*
Complete the function printNumber which takes an integer input from the user and prints it on the screen.

Example 1
Input(user gives value): 7
Output: 7
*/

//Code:
class Solution {
public:
    void printNumber() {
        int x;
        cin >> x;
        cout << x;
    }
};

