/*
Given an unsorted array arr[] of size n, containing elements from the range 1 to n, it is known that one number in this range is missing, and another number occurs twice in the array, find both the duplicate number and the missing number.

Examples:
Input: arr[] = [1, 3, 3] 
Output: [3, 2]
Explanation: Repeating number is 3 and the missing number is 2.

Input: arr[] = [4, 3, 6, 2, 1, 1]
Output: [1, 5]
Explanation: Repeating number is 1 and the missing number is 5.
*/

//Code:
//Approach 1:
class Solution {
  public:
    vector<int> findTwoElement(vector<int>& arr) {
        int n=arr.size();
        
        unordered_map<int,int> mpp;
        
        for(int i=0;i<n;i++)
        {
            mpp[arr[i]]++;
        }
        
        int repeating=-1;
        int missing=-1;
        
        for(int i=1;i<=n;i++) // check numbers from 1 to n
        {
            if(mpp[i]==2) repeating=i;
            if(mpp[i]==0) missing=i;
        }
        
        return {repeating,missing};
    }
};

//Time: O(n)
//Space: O(n)

//Approach 2:
class Solution {
  public:
    vector<int> findTwoElement(vector<int>& arr) {
        int n=arr.size();
        vector<int> freq(n+1,0);
        
        for(int i=0;i<n;i++)
        {
            freq[arr[i]]++;
        }
        
        int repeating=-1;
        int missing=-1;
        
        for(int i=1;i<=n;i++) // check numbers from 1 to n
        {
            if(freq[i]==2) repeating=i;
            if(freq[i]==0) missing=i;
        }
        
        return {repeating,missing};
    }
};

//Time: O(n)
//Space: O(n)

//Approach 3:
class Solution {
  public:
    vector<int> findTwoElement(vector<int>& arr) {
        // long long x; //missing
        // long long y; //repeating
        long long n=arr.size();
        
        long long Sn=n*(n+1)/2; //Sum of n terms
        long long S=0; //Sum of array elements
        long long Pn=(n*(n+1)*(2*n+1))/6; //Sum of squares of n terms
        long long P=0; //Sum of squares of array elments
        
        // S - Sn = y - x = val1
        // P - Pn = y2 - x2
        // P - Pn = (y+x)(y-x)
        // P - Pn = (y+x)*val1
        // (y+x) = (P-Pn)/val1 = val2
        
        //Now, val1=y-x and val2=y+x
        // repeating = y = (val1+val2)/2
        // missing = x = y - val1
        
        for(int i=0;i<n;i++)
        {
            S=S + arr[i];
            P=P + 1LL*arr[i]*arr[i];
        }
        
        long long val1=S-Sn;
        long long val2=(P-Pn)/val1;
        
        long long repeating=(val1+val2)/2;
        long long missing=repeating - val1;
        
        return {(int)repeating,(int)missing};
    }
};

//Time: O(n)
//Space: O(1)
