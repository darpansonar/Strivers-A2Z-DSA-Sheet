/*
You are given a sorted array consisting of only integers where every element appears exactly twice, except for one element which appears exactly once.
Return the single element that appears only once.
Your solution must run in O(log n) time and O(1) space.

Example:
Input: nums = [1,1,2,3,3,4,4,8,8]
Output: 2
*/

//Code:
//Approach 1:
class Solution {
public:
    int singleNonDuplicate(vector<int>& nums) {
        int n=nums.size();
        int max_val=*max_element(nums.begin(),nums.end());
        vector<int> hash(max_val+1,0);

        for(int i=0;i<n;i++)
        {
            hash[nums[i]]++;
        }

        for(int i=0;i<=max_val;i++)
        {
            if(hash[i]==1)
            {
                return i;
            }
        }
        return 0;
    }
};

//Time: O(n + max_val)
//Space: O(max_val)

//Approach 2:
class Solution {
public:
    int singleNonDuplicate(vector<int>& nums) {
        int n=nums.size();
        unordered_map<int,int> mpp;

        for(int i=0;i<n;i++)
        {
            mpp[nums[i]]++;
        }

        for(auto it:mpp)
        {
            if(it.second==1)
            {
                return it.first;
            }
        }
        return -1;
    }
};

//Time: O(n)
//Space: O(n)

//Approach 3:
class Solution {
public:
    int singleNonDuplicate(vector<int>& nums) {
        // a^a=1
        // a^0=a
        int n=nums.size();
        int ans=0;
        for(int i=0;i<n;i++)
        {
            ans=ans^nums[i];
        }
        return ans;
    }
};

//Time: O(n)
//Space: O(1)

//Approach 4: Optimal
class Solution {
public:
    int singleNonDuplicate(vector<int>& nums) {
        //Array : 1 1 2 3 3 4 4 8 8
        //Index : 0 1 2 3 4 5 6 7 8
        //1st occurrence of a element = even index
        //2nd occurrence of a element = odd index

        //Before the single element, pair starts at even index
        //After the single element, pair starts at odd index

        int n=nums.size();

        //Handling edge cases
        if(n==1) return nums[0];
        if(nums[0]!=nums[1]) return nums[0];
        if(nums[n-2]!=nums[n-1]) return nums[n-1];

        int low=1,high=n-2;

        while(low<=high)
        {
            int mid=low+(high-low)/2;
            //Unique element is found
            if(nums[mid]!=nums[mid-1] && nums[mid]!=nums[mid+1])
            {
                return nums[mid];
            }

            //if mid is odd and its pair is correct with previous (even) index then that single element lies on it's right side
            //OR
            //if mid is even and its pair is correct with next (odd) index then that single element lies on it's right side
            if((mid%2==1 && nums[mid]==nums[mid-1]) || 
               (mid%2==0 && nums[mid]==nums[mid+1]))
            {
                low=mid+1;
            }
            
            //else, that single element lies on it's left side
            else
            {
                high=mid-1;
            }
        }
        //Eventually, low==high
        return -1;
    }
};

//Time: O(log n)
//Space: O(1)
