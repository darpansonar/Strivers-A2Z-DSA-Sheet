/*
A digit string is good if the digits (0-indexed) at even indices are even and the digits at odd indices are prime (2, 3, 5, or 7).
For example, "2582" is good because the digits (2 and 8) at even positions are even and the digits (5 and 2) at odd positions are prime. However, "3245" is not good because 3 is at an even index but is not even.
Given an integer n, return the total number of good digit strings of length n. Since the answer may be large, return it modulo 109 + 7.
A digit string is a string consisting of digits 0 through 9 that may contain leading zeros.

Example 1:
Input: n = 1
Output: 5
Explanation: The good numbers of length 1 are "0", "2", "4", "6", "8".

Example 2:
Input: n = 4
Output: 400
*/

//Approach:
class Solution {
public:
    const int MOD=1e9+7;
    int power(long long x,long long n)
    {
        //Using binary/fast exponention
        if(n==0) return 1;

        long long half=power(x,n/2);
        long long result= (half*half)%MOD;

        if(n%2==1) result=(x*result)%MOD;
        return result;
    }
    int countGoodNumbers(long long n) {
        //Even indices : 0,2,4,6,8  -> 5 possibilities
        //Odd indices : 2,3,5,7     -> 4 possibilities

        //No. of even indices in a n digit number = (n+1)/2
        //No. of odd indices in a n digit number = (n)/2

        //For eg: n=6
        //_ _ _ _ _ _
        //Using permutation and combination
        //5*4*5*4*5*4 = Multiplying the possibilities of each index, we get total numbers
        //(5^3)*(4^3)
        //power(5,no. of even indices) * power(4,no. of odd indices)
        //power(5,(n+1)/2)*power(4,n/2)
        
        return (long long)power(5,(n+1)/2) * power(4,n/2) % MOD;
    }
};

//Time: O(log n)
//Space: O(log n)
