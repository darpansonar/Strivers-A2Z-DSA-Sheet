/*
Given n pairs of parentheses, write a function to generate all combinations of well-formed parentheses.

Example:
Input: n = 3
Output: ["((()))","(()())","(())()","()(())","()()()"]
*/

//Approach:
class Solution {
public:
    // open = no. of opening brackets
    // close = no. of closing brackets
    void solve(int open,int close,int n,vector<string> &res,string s)
    {
        if(open==n && close==n)
        {
            res.push_back(s);
            return;
        }
        
        // We can add an opening bracket '('
        // only if we still have some left to use.
        if(open<n) solve(open+1,close,n,res,s+"(");

        // We can add a closing bracket ')'
        // only if the number of closing brackets used so far
        // is less than the number of opening brackets.
        // This ensures the parentheses remain valid.
        if(close<open) solve(open,close+1,n,res,s+")");
    }

    vector<string> generateParenthesis(int n) {
        vector<string> res;
        string s;

        solve(0,0,n,res,s);
        return res;
    }
};

//Time: O(2^n)
//Space: O(n)
