/*
Given an increasing sorted rotated array arr[] of distinct integers. The array is right-rotated k times. Find the value of k.
Let's suppose we have an array arr[] = [2, 4, 6, 9], if we rotate it by 2 times it will look like this:
After 1st Rotation : [9, 2, 4, 6]
After 2nd Rotation : [6, 9, 2, 4]

Examples:
Input: arr[] = [5, 1, 2, 3, 4]
Output: 1
Explanation: The given array is [5, 1, 2, 3, 4]. The original sorted array is [1, 2, 3, 4, 5]. We can see that the array was rotated 1 times to the right.

Input: arr = [1, 2, 3, 4, 5]
Output: 0
Explanation: The given array is not rotated.
*/

//Code:
//Approach 1:
class Solution {
  public:
    int findKRotation(vector<int> &arr) {
        int n=arr.size();
        
        for(int i=0;i<n-1;i++)
        {
            if(arr[i]>arr[i+1])
            {
                return i+1;
            }
        }
        return 0;
    }
};

//Time: O(n)
//Space: O(1)

//Appproach 2:
class Solution {
  public:
    int findKRotation(vector<int> &nums) {
        // minimum element is the first element of sorted part
        // minimum lies in unsorted part
        int n=nums.size();
        int low=0,high=n-1;
        int mini=INT_MAX;
        int index=-1;
        
        while(low<=high)
        {
            int mid=low+(high-low)/2;
            
            //left part is sorted
            if(nums[low]<=nums[mid])
            {
                if(nums[low]<mini)
                {
                    mini=nums[low];
                    index=low;
                }
                low=mid+1;//check for mini in right part
            }
            
            //right part is sorted
            else
            {
                if(nums[mid]<mini)
                {
                    mini=nums[mid];
                    index=mid;
                }
                high=mid-1;//check for mini in left part
            }
        }
        
        //Number of times the array is rotated = index of min element
        return index;
    }
};

//Time: O(log n)
//Space: O(1)
